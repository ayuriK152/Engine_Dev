            </Components>
            <GameObjects>
                <GameObject Name="Camera" PSO="opaque_solid" Tag="Default">
                    <Components>
                        <Component ComponentType="Transform"/>
                        <Component ComponentType="Camera" MainCamera="True"/>
                    </Components>
                </GameObject>
            </GameObjects>
        </GameObject>
    </GameObjects>
</Prefab>